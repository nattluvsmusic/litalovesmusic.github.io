/* ── PRICING NOTE ── */
.note-strip {
  position: relative; z-index: 1;
  padding: 2.5rem 2.5rem;
  background: rgba(191,95,255,0.05);
  border-bottom: 1px solid var(--border);
  display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap;
}
.note-icon {
  font-family: 'Unbounded', sans-serif; font-weight: 900;
  font-size: 3rem; color: var(--purple); flex-shrink: 0; line-height: 1;
}
.note-text {
  font-size: 1.05rem; font-weight: 600;
  color: rgba(245,240,255,0.7); line-height: 1.7;
  border-left: 3px solid var(--purple); padding-left: 1.5rem;
}
.note-text strong { color: var(--green); }

/* ── PRICING GRID ── */
.pricing-section { padding: 4rem 2.5rem; position: relative; z-index: 1; }

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.2rem; margin-top: 2.5rem;
}

.pc {
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px; padding: 2.5rem;
  position: relative; overflow: hidden;
  transition: transform 0.25s;
}
.pc:hover { transform: translateY(-5px); }
.pc.hot-t { border: 2px solid var(--teal); background: rgba(0,255,224,0.04); box-shadow: 0 0 50px rgba(0,255,224,0.08); }
.pc.hot-p { border: 2px solid var(--purple); background: rgba(191,95,255,0.04); box-shadow: 0 0 50px rgba(191,95,255,0.08); }

.pc-badge {
  position: absolute; top: -1px; right: 1.5rem;
  font-family: 'Syne Mono', monospace; font-size: 0.52rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.28rem 0.8rem; border-radius: 0 0 8px 8px;
}
.bg-t { background: var(--teal); color: var(--bg); }
.bg-p { background: var(--purple); color: var(--white); }
.bg-g { background: var(--green); color: var(--bg); }

.pc-type { font-family: 'Syne Mono', monospace; font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem; }
.pc-name { font-family: 'Unbounded', sans-serif; font-weight: 700; font-size: 1.3rem; color: var(--white); }

.pc-price {
  font-family: 'Unbounded', sans-serif; font-weight: 900;
  font-size: 5.5rem; line-height: 1; margin: 0.75rem 0 0.2rem;
  letter-spacing: -0.03em;
}
.pc-price sup { font-size: 2rem; vertical-align: super; }
.col-t { color: var(--teal); }
.col-p { color: var(--purple); }
.col-g { color: var(--green); }
.col-w { color: var(--white); }

.pc-dur { font-family: 'Syne Mono', monospace; font-size: 0.58rem; color: var(--muted); margin-bottom: 1.5rem; }

.pc-features { list-style: none; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.25rem; }
.pc-features li {
  font-size: 0.88rem; font-weight: 600;
  color: rgba(245,240,255,0.8);
  padding: 0.38rem 0;
  display: flex; gap: 0.75rem; align-items: center;
}
.pc-features li::before { content: '✦'; font-size: 0.5rem; flex-shrink: 0; }
.hot-t .pc-features li::before { color: var(--teal); }
.hot-p .pc-features li::before { color: var(--purple); }
.pc:not(.hot-t):not(.hot-p) .pc-features li::before { color: var(--green); }

/* wide card for add-on */
.pc-wide { grid-column: 1 / -1; }

/* ── CTA ── */
.cta-strip {
  position: relative; z-index: 1;
  padding: 4rem 2.5rem;
  border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
  background: linear-gradient(135deg, rgba(200,255,0,0.03), rgba(0,255,224,0.03));
}
.cta-text {
  font-family: 'Unbounded', sans-serif; font-weight: 900;
  font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1;
}

@media(max-width:800px){
  .pricing-grid{grid-template-columns:1fr;}
  .pc-wide{grid-column:auto;}
  .pg-ghost{display:none;}
}
